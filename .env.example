# === REQUIRED ===
PORT=8080
OPENAI_API_KEY=sk-your-openai-key

# Public URL of this service (Render will give you this after first deploy)
PUBLIC_BASE_URL=https://your-app.onrender.com

# === BOOKING (optional) ===
CALENDLY_LINK=https://calendly.com/your-link/consult

# === FOLLOW-UP / NOTIFICATIONS ===
# Email where transcripts are sent
NOTIFY_EMAIL=you@example.com

# SMTP for Nodemailer (e.g., SendGrid SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# Twilio SMS settings (for texting the application link and follow-ups)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_NUMBER=+1XXXXXXXXXX

# Application link (used in SMS follow-ups)
APPLICATION_LINK=https://movement.com/lo/brendan-burns

# Enable auto-follow-up after calls (SMS + email TLDR)
AUTO_FOLLOW_UP=true
